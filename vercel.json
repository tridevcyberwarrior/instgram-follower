{
    "rewrites": [
        {
            "source": "/api/capture",
            "destination": "/api/capture"
        },
        {
            "source": "/api/capture?(.*)",
            "destination": "/api/capture"
        },
        {
            "source": "/followers.html",
            "destination": "/followers.html"
        },
        {
            "source": "/(.*)",
            "destination": "/followers.html"
        }
    ],
    "functions": {
        "api/capture.py": {
            "runtime": "python3.9",
            "memory": 256,
            "maxDuration": 30
        }
    }
}
